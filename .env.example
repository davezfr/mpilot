# MPilot combines acquisition and subtitle/runtime settings.
# Prefer MPILOT_* names for new deployments. Existing QBITLARR_*, BABELARR_*,
# and MST_* names remain supported as compatibility fallbacks.

## Shared

LOG_LEVEL=INFO
MPILOT_ACQUISITION_REQUEST_TIMEOUT_SECONDS=30
MPILOT_ENABLE_ACQUISITION_TOOLS=
MPILOT_ENABLE_SUBTITLE_TOOLS=
MPILOT_DAEMON_LOCK_PATH=

## MPilot acquisition / REST / MCP

MPILOT_ACQUISITION_API_URL=http://127.0.0.1:8000
MPILOT_ACQUISITION_API_KEY=
MPILOT_ACQUISITION_API_TIMEOUT_SECONDS=90
PUID=1000
PGID=1000
TZ=Etc/UTC
FLARESOLVERR_LOG_LEVEL=info

MPILOT_PROWLARR_URL=http://prowlarr:9696
MPILOT_PROWLARR_DOWNLOAD_URL=
MPILOT_PROWLARR_API_KEY=

MPILOT_QBIT_URL=http://host.docker.internal:8080
MPILOT_QBIT_USERNAME=
MPILOT_QBIT_PASSWORD=

MPILOT_ACQUISITION_SAVE_PATH_MOVIE=/downloads/movies
MPILOT_ACQUISITION_SAVE_PATH_MOVIE_4K=/downloads/movies-4k
MPILOT_ACQUISITION_SAVE_PATH_TV=/downloads/tv
MPILOT_ACQUISITION_EXTRA_SAVE_PATHS=

MPILOT_PROWLARR_PRIMARY_INDEXER_IDS=
MPILOT_PROWLARR_FALLBACK_INDEXER_IDS=

MPILOT_ACQUISITION_PREFER_RESOLUTION=1080p
MPILOT_ACQUISITION_PREFER_SOURCE=WEB-DL
MPILOT_ACQUISITION_PREFER_CODEC=H.264
MPILOT_ACQUISITION_MIN_SEEDERS=5
MPILOT_ACQUISITION_DEFAULT_MODE=manual
MPILOT_ACQUISITION_MANUAL_RESULT_LIMIT=4
MPILOT_ACQUISITION_CHOICE_STYLE=hermes-default

MPILOT_ACQUISITION_QUERY_SNAPSHOT_DIR=data/query-snapshots
MPILOT_ACQUISITION_QUERY_SNAPSHOT_RETENTION_SECONDS=604800

MPILOT_ACQUISITION_CLEANUP_ENABLED=false
MPILOT_ACQUISITION_CLEANUP_COMPLETED_AFTER_SECONDS=259200
MPILOT_ACQUISITION_CLEANUP_INTERVAL_SECONDS=21600
MPILOT_ACQUISITION_CLEANUP_INCLUDE_LEGACY_REQUESTER_TAGS=true

MPILOT_ACQUISITION_NOTIFICATION_INTERVAL_SECONDS=3
MPILOT_ACQUISITION_NOTIFICATION_WATCHES_PATH=
MPILOT_ACQUISITION_PROGRESS_TIMEOUT_MESSAGE=Still downloading. Ask for status again to refresh; completion will still notify you.
MPILOT_HERMES_BIN=hermes
MPILOT_HERMES_PROFILE=
MPILOT_TELEGRAM_BOT_TOKEN=
MPILOT_HERMES_ENV_PATH=
MPILOT_ACQUISITION_COMPLETION_HOOK_COMMAND=
MPILOT_ACQUISITION_COMPLETION_HOOK_CWD=
MPILOT_ACQUISITION_COMPLETION_HOOK_PYTHONPATH=

## MPilot subtitles / runtime

MPILOT_SUBTITLE_BACKEND=codex-cli
MPILOT_SUBTITLE_MODEL=gpt-5.4-mini
MPILOT_SUBTITLE_SOURCE_LANGUAGE=en
MPILOT_SUBTITLE_TARGET_LANGUAGE=zh
MPILOT_SUBTITLE_OUTPUT_MODE=bilingual-ass

MPILOT_SUBTITLE_ASS_PRIMARY_SCRIPT=cjk
MPILOT_SUBTITLE_ASS_SECONDARY_SCRIPT=latin
MPILOT_SUBTITLE_ASS_HEIGHT=1080

# PLEX_BASE_URL=http://127.0.0.1:32400
