[Unit]
Description=MPilot daemon
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/absolute/path/to/mpilot
Environment=PYTHON=/absolute/path/to/mpilot/.venv/bin/python
ExecStart=/absolute/path/to/mpilot/bin/mpilot-daemon
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
