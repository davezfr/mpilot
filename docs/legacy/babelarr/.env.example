# Translation backend.
#
# Reference backend tested by the project:
BABELARR_BACKEND=codex-cli
BABELARR_MODEL=gpt-5.4-mini

# Experimental OpenAI-compatible endpoint alternative. It uses the same
# translation contract, but instruction-following and cue alignment can vary by
# model/server and are not guaranteed by the reference test path.
# BABELARR_BACKEND=openai-compatible
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama

# ASS output defaults.
BABELARR_ASS_PRIMARY_SCRIPT=cjk
BABELARR_ASS_SECONDARY_SCRIPT=latin
BABELARR_ASS_HEIGHT=1080

# Optional Plex resolver settings.
# PLEX_BASE_URL=http://127.0.0.1:32400
# PLEX_TOKEN=replace-with-your-plex-token
# BABELARR_PLEX_PATH_PREFIX="/server/media"
# BABELARR_LOCAL_PATH_PREFIX="/mnt/media"

# Optional persistent job store. BABELARR_JOB_STORE_DIR is preferred for new
# installs. MST_JOB_STORE_DIR remains supported for compatibility.
# BABELARR_JOB_STORE_DIR=~/.local/share/babelarr/jobs

# Optional qBitlarr container → host path rewrite. Used by the workflow runtime
# whenever an external caller (qBitlarr completion hook, bot, MCP tool) hands in
# a container-side content_path/video_path. Without this, paths like
# "/media/Movies - HD/..." reach Babelarr verbatim and fail with EROFS on the host.
# BABELARR_RUNTIME_CONTENT_PATH_PREFIX="/media"
# BABELARR_RUNTIME_LOCAL_CONTENT_PATH_PREFIX="/mnt/media"

# Optional online subtitle provider search.
# BABELARR_SUBTITLE_PROVIDER=opensubtitles
# OPENSUBTITLES_API_KEY=replace-with-your-opensubtitles-api-key
# OPENSUBTITLES_USER_AGENT="Babelarr v0.1.0"
# OPENSUBTITLES_USERNAME=replace-with-your-opensubtitles-username
# OPENSUBTITLES_PASSWORD=replace-with-your-opensubtitles-password
# OPENSUBTITLES_TOKEN=replace-with-optional-bearer-token
# SUBDL_API_KEY=replace-with-your-subdl-api-key
