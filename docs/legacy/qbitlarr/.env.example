# qBitlarr listens on http://localhost:8000 when started with docker compose.
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30

# Optional REST/MCP API key. When set, every request must send:
# X-API-Key: this-value
QBITLARR_API_KEY=

# Used by the bundled Prowlarr and FlareSolverr containers.
PUID=1000
PGID=1000
TZ=Etc/UTC
FLARESOLVERR_LOG_LEVEL=info

# Internal Prowlarr URL used by qBitlarr inside the compose network.
# The compose file defaults to this value, so most users can leave it unchanged.
PROWLARR_URL=http://prowlarr:9696

# Optional base URL for Prowlarr-generated torrent proxy links.
# Leave blank when using the bundled Prowlarr container. Set this only when
# qBitlarr must rewrite Prowlarr links before fetching .torrent files,
# for example http://host.docker.internal:9696 or http://192.168.1.10:9696.
PROWLARR_DOWNLOAD_URL=

# Create this after first starting Prowlarr:
# Settings -> General -> Security -> API Key.
PROWLARR_API_KEY=

# qBitlarr does not run qBittorrent. Install qBittorrent separately, enable
# Preferences/Options -> Web UI, then put that Web UI address and login here
# before starting the qbitlarr service.
# From inside Docker, localhost means the qBitlarr container, not your host machine.
# If qBittorrent runs on the Docker host, use http://host.docker.internal:8080.
# If qBittorrent runs on a NAS or another machine, use its LAN URL.
QBIT_URL=http://host.docker.internal:8080
QBIT_USERNAME=
QBIT_PASSWORD=

# qBittorrent save paths used by /handle and /download defaults. TV downloads
# create a show folder under QBITLARR_SAVE_PATH_TV, e.g. /downloads/tv/Example Show.
# save_path overrides must be inside these roots or inside QBITLARR_EXTRA_SAVE_PATHS.
QBITLARR_SAVE_PATH_MOVIE=/downloads/movies
QBITLARR_SAVE_PATH_MOVIE_4K=/downloads/movies-4k
QBITLARR_SAVE_PATH_TV=/downloads/tv
QBITLARR_EXTRA_SAVE_PATHS=

# Optional comma-separated Prowlarr indexer IDs.
# Primary IDs are searched first for normal requests. Fallback IDs are searched
# when primary results are missing or unsuitable.
# Discover IDs with GET /prowlarr/indexers after qBitlarr is running.
# Example: PROWLARR_PRIMARY_INDEXER_IDS=1,2,3
PROWLARR_PRIMARY_INDEXER_IDS=
PROWLARR_FALLBACK_INDEXER_IDS=

# Quality preferences. These are the defaults qBitlarr ranks releases against
# and uses as the "match" gate when auto-selecting a release.
# Resolution: 480p, 720p, 1080p, 2160p
# Source:     WEB-DL, WEBRip, BluRay, HDTV
# Codec:      H.264, H.265
# Users can override per request by saying "4K", "Remux", "720p", etc. in the
# message — these env vars only set the default when nothing is specified.
QBITLARR_PREFER_RESOLUTION=1080p
QBITLARR_PREFER_SOURCE=WEB-DL
QBITLARR_PREFER_CODEC=H.264
QBITLARR_MIN_SEEDERS=5

# Default behavior of /handle when an IMDb ID is given.
#   auto    = pick the best release and queue it
#   manual  = always return ranked results, never auto-download
#   confirm = return the top pick + alternatives, do not queue
QBITLARR_DEFAULT_MODE=manual

# Release-choice display defaults to stock Hermes-style clarify: four choices,
# with the chat host appending its own "Other" option. Custom Telegram adapters
# can set 5/telegram-rich, send choice_rich_message via sendRichMessage, and
# render choice_buttons as one inline row.
QBITLARR_MANUAL_RESULT_LIMIT=4
QBITLARR_CHOICE_STYLE=hermes-default

# Query snapshots back manual result picking and are pruned by the maintenance
# loop even when completed-task cleanup is disabled. Default: 7 days.
QBITLARR_QUERY_SNAPSHOT_DIR=data/query-snapshots
QBITLARR_QUERY_SNAPSHOT_RETENTION_SECONDS=604800

# Optional completed-task cleanup. Disabled by default. When enabled, qBitlarr
# periodically removes only qBitlarr-managed completed torrent tasks after the
# configured age, and never deletes downloaded files. New tasks receive the
# qbitlarr.managed tag; legacy requester.* tags can also be included.
QBITLARR_CLEANUP_ENABLED=false
QBITLARR_CLEANUP_COMPLETED_AFTER_SECONDS=259200
QBITLARR_CLEANUP_INTERVAL_SECONDS=21600
QBITLARR_CLEANUP_INCLUDE_LEGACY_REQUESTER_TAGS=true

# Optional MCP-side completion notifications. These are only used by the
# stdio MCP wrapper when an agent passes notification_target, for example
# telegram:123456789. They are not used by the Docker API container itself.
QBITLARR_NOTIFICATION_INTERVAL_SECONDS=3
# Leave blank for the default:
# $XDG_DATA_HOME/qbitlarr/download-notification-watches.json, or
# ~/.local/share/qbitlarr/download-notification-watches.json when XDG_DATA_HOME is unset.
QBITLARR_NOTIFICATION_WATCHES_PATH=
QBITLARR_PROGRESS_TIMEOUT_MESSAGE=Still downloading. Ask for status again to refresh; completion will still notify you.
QBITLARR_HERMES_BIN=hermes
QBITLARR_HERMES_PROFILE=
# Optional direct Telegram status transport. When set, qBitlarr can update the
# same progress message in place. If omitted, it falls back to Hermes send.
# For named Hermes profiles, point QBITLARR_HERMES_ENV_PATH at that profile's
# .env. When omitted, qBitlarr checks HERMES_HOME/.env before ~/.hermes/.env.
QBITLARR_TELEGRAM_BOT_TOKEN=
QBITLARR_HERMES_ENV_PATH=

# Optional command to run after a watched download reaches 100%. The MCP
# wrapper sends a completion-event JSON document to the command's stdin.
# Example: /path/to/python -m media_workflow_runtime.cli handle-qbitlarr-completion
QBITLARR_COMPLETION_HOOK_COMMAND=
QBITLARR_COMPLETION_HOOK_CWD=
QBITLARR_COMPLETION_HOOK_PYTHONPATH=
